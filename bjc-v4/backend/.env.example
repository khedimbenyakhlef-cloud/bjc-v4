# ============================================================
# BENY-JOE CLOUD V4 — Variables d'environnement
# ============================================================

# --- Serveur ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost

# --- PostgreSQL ---
DATABASE_URL=postgresql://beny:CHANGE_ME@postgres:5432/benycloud
DB_HOST_FOR_APPS=postgres

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
MINIO_BUCKET=sites

# --- JWT ---
# Générer: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_64_CHARS_MIN
JWT_EXPIRES_IN=7d

# --- Sessions ---
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_64_CHARS

# --- Chiffrement des secrets (variables d'environnement des apps) ---
# Exactement 32 caractères
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARS_HERE!!

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback

# --- Domaine de base ---
BASE_DOMAIN=benyjoecloud.com

# --- Docker ---
DOCKER_SOCKET=/var/run/docker.sock

# --- IA ---
DEEPSEEK_API_KEY=your_deepseek_api_key

# --- Limites ---
MAX_UPLOAD_SIZE_MB=100
MAX_APPS_PER_USER=10

# --- DB pour les apps utilisateur (hôte accessible depuis les containers) ---
DB_HOST_FOR_APPS=postgres
